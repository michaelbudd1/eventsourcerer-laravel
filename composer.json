{
    "name": "eventsourcerer/event-sourcerer-laravel",
    "description": "Laravel client for EventSourcerer",
    "type": "library",
    "autoload": {
        "psr-4": {
            "PearTreeWeb\\EventSourcerer\\LaravelClient\\": "src/"
        }
    },
    "authors": [
        {
            "name": "Pear Tree Web Ltd",
            "email": "contact@peartreeweb.com"
        }
    ],
    "require": {
        "php": ">=8.5",
        "eventsourcerer/event-sourcerer-client": "dev-main",
        "eventsourcerer/common": "dev-main"
    },
    "extra": {
        "laravel": {
            "providers": [
                "PearTreeWeb\\EventSourcerer\\LaravelClient\\Providers\\EventSourcererProvider"
            ]
        }
    },
    "minimum-stability": "dev"
}
